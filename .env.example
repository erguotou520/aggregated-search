# Aggregated Search — 环境变量配置
# 复制此文件为 .env 并填写实际值
# 所有引擎均为可选，未配置的引擎会自动跳过
# DuckDuckGo 无需 API Key，始终作为兜底引擎

# ── SearXNG (自托管，优先级最高) ──────────────────────────────
# 自建实例地址，结尾不带斜杠
SEARXNG_URL=http://localhost:8081

# ── Serper.dev (Google 搜索封装) ─────────────────────────────
# 获取地址: https://serper.dev
# SERPER_API_KEY=your_serper_api_key_here

# ── Tavily (AI 优化搜索) ──────────────────────────────────────
# 获取地址: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ── Bing Web Search API v7 ────────────────────────────────────
# 获取地址: https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
# BING_API_KEY=your_bing_api_key_here
# BING_ENDPOINT=https://api.bing.microsoft.com  # 可选，默认值

# ── Ollama 云端 Web Search ────────────────────────────────────
# 获取地址: https://ollama.com/settings/keys
# OLLAMA_API_KEY=your_ollama_api_key_here
